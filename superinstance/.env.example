# SuperInstance Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# DATABASE
# ===========================================
# SQLite database URL (default is fine for local use)
DATABASE_URL=file:/home/z/my-project/db/custom.db

# ===========================================
# AI MODEL PROVIDERS (Optional - for cloud fallback)
# ===========================================
# OpenAI API key for cloud distillation/fallback
OPENAI_API_KEY=YOUR_OPENAI_KEY_HERE

# Anthropic API key for cloud distillation/fallback
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_KEY_HERE

# Local model endpoint (for custom model servers)
LOCAL_MODEL_ENDPOINT=http://localhost:8080

# ===========================================
# CHANNEL INTEGRATIONS
# ===========================================
# Discord Bot Token (get from https://discord.com/developers)
DISCORD_BOT_TOKEN=YOUR_DISCORD_BOT_TOKEN_HERE
DISCORD_CHANNEL_ID=YOUR_CHANNEL_ID_HERE

# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=YOUR_CHAT_ID_HERE

# WhatsApp Business API (optional)
WHATSAPP_TOKEN=YOUR_WHATSAPP_TOKEN_HERE
WHATSAPP_PHONE_ID=YOUR_PHONE_ID_HERE

# Generic Webhook URL
WEBHOOK_URL=YOUR_WEBHOOK_URL_HERE

# ===========================================
# AGENT SYSTEM CONNECTIONS
# ===========================================
# OpenClaw endpoint (for two-way synergy)
OPENCLAW_ENDPOINT=http://localhost:3000
OPENCLAW_API_KEY=YOUR_OPENCLAW_KEY_HERE

# LangChain endpoint
LANGCHAIN_ENDPOINT=http://localhost:8000

# ===========================================
# RANCH CONFIGURATION
# ===========================================
# Maximum VRAM to use (in GB) - Jetson Nano 8GB recommended: 6
MAX_VRAM_GB=6

# Night School time (24h format)
NIGHT_SCHOOL_TIME=02:00

# Culling threshold (0.0-1.0) - agents below this are removed
CULL_THRESHOLD=0.4

# Base model selection (phi-3-mini, mamba, llama-3-8b)
BASE_MODEL=phi-3-mini

# ===========================================
# JETSON-SPECIFIC (for NVIDIA Jetson devices)
# ===========================================
# Enable DLA (Deep Learning Accelerator) for power savings
USE_DLA=true

# Power mode (0=MAXN, 1=15W, 2=10W)
JETSON_POWER_MODE=0

# ===========================================
# MONITORING & OBSERVABILITY
# ===========================================
# Prometheus metrics endpoint (optional)
PROMETHEUS_PORT=9090

# Log level (trace, debug, info, warn, error)
RUST_LOG=info

# Enable JSON logging
JSON_LOGS=false
