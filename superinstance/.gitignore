# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ===========================================
# SECRETS (NEVER COMMIT)
# ===========================================
.env
.env.*
!.env.example
*.pem
*.key
secrets/

# ===========================================
# DEPENDENCIES
# ===========================================
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ===========================================
# BUILD OUTPUTS
# ===========================================
# Next.js
/.next/
/out/

# Rust
target/
**/*.rs.bk
Cargo.lock

# General
/build/
/dist/
*.exe
*.exe~
*.dll
*.so
*.dylib

# ===========================================
# TESTING & COVERAGE
# ===========================================
/coverage
*.profraw
*.profdata

# ===========================================
# LOGS & DEBUG
# ===========================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
server.log
dev.log

# ===========================================
# EDITORS & IDES
# ===========================================
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-*

# ===========================================
# OS FILES
# ===========================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ===========================================
# TEMPORARY FILES
# ===========================================
tmp/
temp/
*.tmp
*.temp
.cache/

# ===========================================
# SUPERINSTANCE SPECIFIC
# ===========================================
# Local config
local-*
.claude
.z-ai-config
test/
prompt

# Database (keep schema, ignore data)
*.db
*.db-journal
*.sqlite
*.sqlite3
!prisma/schema.prisma

# Model weights (too large for git)
*.safetensors
*.bin
*.gguf
*.pth
*.pt
!pasture/base_models/README.md

# Generated gene pool cache
genetics/cache/

# Night School outputs
night_school/offspring/
night_school/quarantine/

# ===========================================
# DEPLOYMENT
# ===========================================
.vercel
.netlify
.firebase/

# ===========================================
# SKILLS DIRECTORY
# ===========================================
/skills/

# ===========================================
# WORKLOG & NOTES
# ===========================================
worklog.md
*.md.bak
